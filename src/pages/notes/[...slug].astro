---
import { getCollection, render } from 'astro:content';
import Layout from '@/components/Layout.astro';
import BackLink from '@/components/BackLink.astro';
import SEO from '@/components/SEO.astro';
import { formatDate } from '@/lib/format';
import { blogPostingSchema } from '@/lib/jsonld';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id.replace(/\.mdx?$/, '') },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const slug = note.id.replace(/\.mdx?$/, '');
const jsonLd = blogPostingSchema({
  title: note.data.title,
  description: note.data.description,
  publishedAt: note.data.date,
  updatedAt: note.data.updated,
  slug,
});
---

<Layout title={note.data.title} description={note.data.description}>
  <SEO
    slot="head"
    title={note.data.title}
    description={note.data.description}
    ogType="article"
    publishedAt={note.data.date}
    updatedAt={note.data.updated}
    tags={note.data.tags}
  />
  <script
    is:inline
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(jsonLd)}
  />
  <BackLink />
  <header class="note-header">
    <h1>{note.data.title}</h1>
    <p class="note-date">
      {formatDate(note.data.date)}{note.data.updated ? ` · updated ${formatDate(note.data.updated)}` : ''}
    </p>
  </header>
  <article class="note-body">
    <Content />
  </article>
</Layout>

<style is:global>
  .note-header {
    margin-top: 2rem;
    margin-bottom: 2.5rem;
  }
  .note-header h1 {
    font-family: var(--font-mono);
    font-size: 34px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0 0 0.5rem 0;
    color: var(--color-text-primary);
  }
  .note-date {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .note-body {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-text-primary);
  }
  .note-body > * + * {
    margin-top: 1.25rem;
  }
  .note-body h1,
  .note-body h2,
  .note-body h3,
  .note-body h4,
  .note-body h5,
  .note-body h6 {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 17px;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }
  .note-body p {
    margin: 0 0 1.25rem 0;
  }
  .note-body a {
    color: var(--color-text-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .note-body pre {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
    background: var(--bg-secondary);
    padding: 1rem 1.25rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .note-body pre code {
    font-family: inherit;
    font-size: inherit;
    background: none;
    padding: 0;
    border-radius: 0;
  }
  .note-body :not(pre) > code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--bg-secondary);
    padding: 1px 6px;
    border-radius: 4px;
  }
  .note-body blockquote {
    font-family: var(--font-serif);
    font-style: italic;
    border-left: 2px solid var(--color-border);
    padding-left: 16px;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
  }
  .note-body blockquote p {
    margin: 0;
  }
  .note-body ul,
  .note-body ol {
    margin: 0 0 1.25rem 1.5rem;
    padding: 0;
  }
  .note-body li {
    margin: 0.25rem 0;
  }
  .note-body svg {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5rem auto;
  }
  .note-body img {
    max-width: 100%;
    height: auto;
  }
</style>
