---
import Layout from '@/components/Layout.astro';
import SectionLabel from '@/components/SectionLabel.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '@/lib/format';
import { visibleCurrently } from '@/data/now';
import { personSchema } from '@/lib/jsonld';
import { getGalleryPhotos, variantUrl } from '@/lib/photos';

const description =
  'backend/aiml engineer in boston. distributed systems by day, photography at night.';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const personLd = JSON.stringify(personSchema());
const previewPhotos = getGalleryPhotos().slice(0, 8);
---

<Layout description={description}>
  <Fragment slot="head">
    <title>anish sahoo</title>
    <link rel="canonical" href="https://asahoo.dev/" />
    <meta property="og:url" content="https://asahoo.dev/" />
    <meta property="og:image" content="https://asahoo.dev/og-default.png" />
    <meta name="twitter:image" content="https://asahoo.dev/og-default.png" />
    <meta property="og:title" content="anish sahoo" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="anish sahoo" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="anish sahoo" />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" set:html={personLd} />
  </Fragment>

  <header class="home-header">
    <h1>Anish Sahoo</h1>
    <p class="tagline">Backend/AI/ML Engineer · Boston, MA</p>
  </header>

  <section class="bio">
    <p>
      I build distributed systems and AI/ML platforms by day. On weekends I shoot Fujifilm
      and chase the dream frequency response.
    </p>
    <p>This site is intentionally plain. It loads in one round trip.</p>
  </section>

  <section class="block">
    <h2 class="visually-hidden">notes</h2>
    <SectionLabel>NOTES</SectionLabel>
    <ul class="row-list">
      {
        notes.map((n) => (
          <li class="row">
            <a href={`/notes/${n.id}`} class="row-title">{n.data.title}</a>
            <time datetime={n.data.date.toISOString()} class="row-date">
              {formatDate(n.data.date)}
            </time>
          </li>
        ))
      }
      <li class="row row-all">
        <a href="/notes">all notes →</a>
      </li>
    </ul>
  </section>

  <section class="block">
    <h2 class="visually-hidden">currently</h2>
    <SectionLabel>CURRENTLY</SectionLabel>
    <dl class="currently">
      {
        visibleCurrently().slice(0, 5).map((entry) => (
          <div class="currently-row">
            <dt>{entry.label}</dt>
            <dd>{entry.value}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section class="block">
    <h2 class="visually-hidden">photos</h2>
    <SectionLabel>PHOTOS</SectionLabel>
    <div class="carousel-wrap">
      <button class="carousel-btn carousel-prev" aria-label="Previous photos">‹</button>
      <div class="photo-carousel" id="photo-carousel">
        {previewPhotos.map((p) => (
          <a href="/photos" class="photo-thumb">
            <img
              src={variantUrl(p.id, 800, 'webp')}
              alt={p.alt}
              loading="lazy"
              decoding="async"
              style={`background-image: url('${p.lqip}'); background-size: cover; background-position: center;`}
            />
          </a>
        ))}
      </div>
      <button class="carousel-btn carousel-next" aria-label="Next photos">›</button>
    </div>
    <p class="photo-all"><a href="/photos">all photos →</a></p>

    <script>
      const carousel = document.getElementById('photo-carousel');
      document.querySelector('.carousel-prev')?.addEventListener('click', () => {
        carousel?.scrollBy({ left: -300, behavior: 'smooth' });
      });
      document.querySelector('.carousel-next')?.addEventListener('click', () => {
        carousel?.scrollBy({ left: 300, behavior: 'smooth' });
      });
    </script>
  </section>

  <section class="block">
    <h2 class="visually-hidden">elsewhere</h2>
    <SectionLabel>ELSEWHERE</SectionLabel>
    <p class="elsewhere">
      <a href="/projects">projects</a>
      <span class="sep"> · </span>
      <a href="https://github.com/anish-sahoo" target="_blank" rel="noopener">github</a>
      <button
        type="button"
        class="sep sep-toggle"
        aria-label="toggle theme"
        onclick="window.toggleTheme && window.toggleTheme()"
      > · </button>
      <a href="mailto:sahoo.an@northeastern.edu">email</a>
      <span class="sep"> · </span>
      <a href="/resume.pdf" target="_blank" rel="noopener" class="resume-btn">resume ↓</a>
    </p>
  </section>
</Layout>

<style>
  .home-header {
    margin-top: 3rem;
  }
  .home-header h1 {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 32px;
    margin: 0 0 0.35rem 0;
    letter-spacing: -0.01em;
  }
  .tagline {
    color: var(--color-text-secondary);
    margin: 0;
    font-size: 14px;
  }
  .bio {
    margin-top: 2rem;
    color: var(--color-text-secondary);
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.65;
  }
  .bio p {
    margin: 0 0 0.75rem 0;
  }
  .block {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .row-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.15rem 0;
  }
  .row-title {
    text-decoration: none;
  }
  .row-title:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .row-date {
    color: var(--color-text-tertiary);
    font-size: 13px;
    white-space: nowrap;
  }
  .row-all {
    margin-top: 0.5rem;
  }
  .row-all a {
    color: var(--color-text-tertiary);
    text-decoration: none;
  }
  .row-all a:hover {
    text-decoration: underline;
  }
  .currently {
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1.25rem;
    row-gap: 0.25rem;
  }
  .currently-row {
    display: contents;
  }
  .currently dt {
    color: var(--color-text-tertiary);
  }
  .currently dd {
    margin: 0;
    color: var(--color-text-primary);
  }
  .carousel-wrap {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .photo-carousel {
    display: flex;
    gap: 0.4rem;
    height: 110px;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    flex: 1;
  }
  .photo-carousel::-webkit-scrollbar {
    display: none;
  }
  .photo-thumb {
    flex: 0 0 auto;
    height: 100%;
    overflow: hidden;
    border-radius: 2px;
    text-decoration: none;
    scroll-snap-align: start;
    transition: opacity 0.2s;
  }
  .photo-thumb img {
    height: 100%;
    width: auto;
    display: block;
  }
  .photo-carousel:hover .photo-thumb {
    opacity: 0.6;
  }
  .photo-carousel:hover .photo-thumb:hover {
    opacity: 1;
  }
  .carousel-btn {
    flex: 0 0 auto;
    font-size: 20px;
    line-height: 1;
    color: var(--color-text-tertiary);
    padding: 0 0.1rem;
    cursor: pointer;
    user-select: none;
    transition: color 0.15s;
  }
  .carousel-btn:hover {
    color: var(--color-text-primary);
  }
  .photo-all {
    margin: 0.6rem 0 0 0;
  }
  .photo-all a {
    color: var(--color-text-tertiary);
    text-decoration: none;
    font-size: 13px;
  }
  .photo-all a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .elsewhere {
    margin: 0 0 2.5rem 0;
  }
  .elsewhere a {
    text-decoration: none;
  }
  .elsewhere a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .resume-btn {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    font-size: 13px;
    text-decoration: none !important;
    vertical-align: middle;
  }
  .resume-btn:hover {
    background: var(--color-bg-secondary);
    opacity: 1 !important;
    text-decoration: none !important;
  }
  .sep {
    color: var(--color-text-tertiary);
  }
  .sep-toggle {
    color: var(--color-text-tertiary);
    font: inherit;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
